rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        getRole() == 'admin' || 
        request.auth.token.email == 'admin@creatorconnect.in' ||
        request.auth.token.email == 'shyamabp27@gmail.com'
      );
    }
    

    // 1. users
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    // 2. creators
    match /creators/{creatorId} {
      // Public directory — any user can browse creator profiles (status filter done client-side)
      allow read: if true;
      allow create, update: if isOwner(creatorId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // 3. businesses
    match /businesses/{businessId} {
      allow read: if true; // Public directories access
      allow create, update: if isOwner(businessId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // 4. bookings
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.businessId || 
        request.auth.uid == resource.data.creatorId || 
        isAdmin()
      );
      allow create: if isAuthenticated() && getRole() == 'business';
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.businessId || 
        request.auth.uid == resource.data.creatorId || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    // 5. reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.reviewerId
      );
      allow update, delete: if isAdmin();
    }
    
    // 6. admin_settings
    match /admin_settings/{settingId} {
      allow read: if true; // Public branding metadata and currency settings
      allow write: if isAdmin();
    }
    
    // 7. commissions
    match /commissions/{overrideId} {
      allow read, write: if isAdmin();
    }
    
    // 8. notifications
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated(); // Allowed to trigger notifications on actions
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
  }
}
